<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SOL Arb Bot</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080c10;--s1:#0d1218;--s2:#111820;
  --g:#00ff88;--gd:rgba(0,255,136,0.12);
  --a:#f5a623;--r:#ff4757;--b:#4ecdc4;
  --t:#e8f0e9;--td:#5a7a65;--tm:#8aab90;
  --br:rgba(0,255,136,0.12);--br2:rgba(0,255,136,0.06);
  --mono:'JetBrains Mono',monospace;
  --sans:'Space Grotesk',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--t);font-family:var(--sans);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,255,136,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,.025) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(8,12,16,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--br2);padding:14px 0}
.nav-inner{max-width:1100px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-icon{width:34px;height:34px;background:var(--gd);border:1px solid var(--br);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px}
.nav-logo-name{font-size:14px;font-weight:700;color:var(--t)}
.nav-links{display:flex;align-items:center;gap:8px}
.nav-a{padding:7px 14px;border-radius:8px;font-size:12px;font-family:var(--mono);text-decoration:none;border:1px solid transparent;transition:all .15s}
.nav-ghost{color:var(--tm);border-color:var(--br2)}
.nav-ghost:hover{color:var(--t);border-color:var(--br)}
.nav-cta{background:var(--gd);border-color:var(--br);color:var(--g);font-weight:600}
.nav-cta:hover{background:rgba(0,255,136,.2)}

/* WRAPPER */
.wrap{max-width:1100px;margin:0 auto;padding:0 24px;position:relative;z-index:1}

/* HERO */
.hero{padding:80px 0 56px;text-align:center}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--s1);border:1px solid var(--br);border-radius:100px;padding:6px 16px;font-size:11px;font-family:var(--mono);color:var(--g);margin-bottom:28px}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--g);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hero h1{font-size:clamp(36px,6vw,64px);font-weight:700;line-height:1.08;margin-bottom:20px;letter-spacing:-1px}
.hero h1 em{color:var(--g);font-style:normal}
.hero h1 small{color:var(--tm);font-size:.85em}
.hero p{font-size:17px;color:var(--tm);max-width:520px;margin:0 auto 36px;line-height:1.65}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn{padding:13px 26px;border-radius:10px;font-size:13px;font-family:var(--mono);font-weight:600;text-decoration:none;border:1px solid transparent;transition:all .2s}
.btn-primary{background:var(--gd);border-color:var(--br);color:var(--g)}
.btn-primary:hover{background:rgba(0,255,136,.22);transform:translateY(-1px)}
.btn-ghost{background:var(--s1);border-color:var(--br2);color:var(--tm)}
.btn-ghost:hover{border-color:var(--br);color:var(--t)}

/* TICKER */
.ticker{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--br2);border:1px solid var(--br2);border-radius:12px;overflow:hidden;margin:40px 0 60px}
.tick{background:var(--s1);padding:20px 16px;text-align:center}
.tick-val{font-size:20px;font-weight:700;font-family:var(--mono);color:var(--g)}
.tick-lbl{font-size:10px;font-family:var(--mono);color:var(--td);text-transform:uppercase;letter-spacing:1px;margin-top:4px}

/* PAGE CARDS */
.pages-title{text-align:center;margin-bottom:32px}
.pages-title h2{font-size:32px;font-weight:700;margin-bottom:8px}
.pages-title p{font-size:15px;color:var(--tm)}
.pages-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:64px}
.page-card{background:var(--s1);border:1px solid var(--br2);border-radius:16px;overflow:hidden;text-decoration:none;display:block;transition:all .2s;position:relative}
.page-card:hover{border-color:var(--br);transform:translateY(-3px);box-shadow:0 8px 32px rgba(0,255,136,.06)}
.page-card-top{padding:28px 28px 20px}
.page-card-icon{font-size:36px;margin-bottom:14px;display:block}
.page-card-title{font-size:18px;font-weight:700;color:var(--t);margin-bottom:8px}
.page-card-desc{font-size:13px;color:var(--tm);line-height:1.65}
.page-card-tag{display:inline-block;font-size:10px;font-family:var(--mono);padding:3px 8px;border-radius:4px;margin-top:10px;text-transform:uppercase;letter-spacing:.5px}
.tag-live{background:rgba(0,255,136,.1);color:var(--g)}
.tag-paper{background:rgba(245,166,35,.1);color:var(--a)}
.tag-invest{background:rgba(78,205,196,.1);color:var(--b)}
.tag-code{background:rgba(255,71,87,.1);color:var(--r)}
.page-card-bottom{padding:14px 28px;border-top:1px solid var(--br2);display:flex;align-items:center;justify-content:space-between}
.page-card-link{font-size:11px;font-family:var(--mono);color:var(--g)}
.page-card-arrow{color:var(--g);font-size:16px}

/* FEATURES */
.features{margin-bottom:64px}
.section-label{font-size:11px;font-family:var(--mono);color:var(--g);text-transform:uppercase;letter-spacing:2px;margin-bottom:10px}
.section-h{font-size:30px;font-weight:700;margin-bottom:10px}
.section-p{font-size:15px;color:var(--tm);max-width:480px;line-height:1.6;margin-bottom:36px}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.feat{background:var(--s1);border:1px solid var(--br2);border-radius:14px;padding:22px}
.feat-icon{font-size:22px;margin-bottom:12px}
.feat-title{font-size:14px;font-weight:600;margin-bottom:6px}
.feat-desc{font-size:12px;color:var(--tm);line-height:1.6}

/* STEPS */
.steps{margin-bottom:64px}
.steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.step{background:var(--s1);border:1px solid var(--br2);border-radius:14px;padding:22px;position:relative}
.step-num{font-size:36px;font-weight:700;font-family:var(--mono);color:var(--br);line-height:1;margin-bottom:10px}
.step-title{font-size:13px;font-weight:600;color:var(--g);margin-bottom:6px}
.step-desc{font-size:12px;color:var(--tm);line-height:1.6}

/* CTA BANNER */
.cta-banner{background:var(--s1);border:1px solid var(--br);border-radius:16px;padding:48px;text-align:center;margin-bottom:48px;position:relative;overflow:hidden}
.cta-banner::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--g),transparent)}
.cta-banner h2{font-size:30px;font-weight:700;margin-bottom:10px}
.cta-banner p{color:var(--tm);margin-bottom:28px;font-size:15px}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
footer{border-top:1px solid var(--br2);padding:20px 0;position:relative;z-index:1}
.foot-inner{max-width:1100px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
.foot-text{font-size:11px;font-family:var(--mono);color:var(--td)}
.foot-links{display:flex;gap:20px}
.foot-links a{font-size:11px;font-family:var(--mono);color:var(--td);text-decoration:none}
.foot-links a:hover{color:var(--g)}

/* RESPONSIVE */
@media(max-width:768px){
  .pages-grid{grid-template-columns:1fr}
  .feat-grid{grid-template-columns:1fr 1fr}
  .steps-grid{grid-template-columns:1fr 1fr}
  .ticker{grid-template-columns:1fr 1fr}
  .nav-links .nav-ghost{display:none}
}
@media(max-width:480px){
  .feat-grid,.steps-grid{grid-template-columns:1fr}
  .hero h1{font-size:32px}
  .cta-banner{padding:28px 20px}
}
</style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a class="nav-logo" href="index.html">
      <div class="nav-logo-icon">◆</div>
      <div class="nav-logo-name">SOL ARB BOT</div>
    </a>
    <div class="nav-links">
      <a class="nav-a nav-ghost" href="dashboard.html">Dashboard</a>
      <a class="nav-a nav-ghost" href="paper-dashboard.html">Paper Trader</a>
      <a class="nav-a nav-ghost" href="investor-portal.html">How it works</a>
      <a class="nav-a nav-cta" href="investor-portal.html">Invest ↗</a>
    </div>
  </div>
</nav>

<div class="wrap">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-badge"><div class="hero-dot"></div>Live on Solana Mainnet</div>
    <h1>Automated arbitrage.<br><em>Real profits.</em><br><small>No manual trading.</small></h1>
    <p>The bot scans 12+ token pairs across Raydium, Orca, Jupiter, and Meteora every 500ms — executing profitable trades faster than any human.</p>
    <div class="hero-btns">
      <a class="btn btn-primary" href="investor-portal.html">◆ Deposit SOL & Earn</a>
      <a class="btn btn-ghost" href="dashboard.html">View Live Dashboard</a>
    </div>
  </div>

  <!-- TICKER -->
  <div class="ticker">
    <div class="tick"><div class="tick-val" id="solPrice">$--.--</div><div class="tick-lbl">SOL / USD</div></div>
    <div class="tick"><div class="tick-val">25%</div><div class="tick-lbl">Performance Fee</div></div>
    <div class="tick"><div class="tick-val">7 days</div><div class="tick-lbl">Withdrawal Lockup</div></div>
    <div class="tick"><div class="tick-val">0.5 SOL</div><div class="tick-lbl">Min Deposit</div></div>
  </div>

  <!-- PAGE CARDS -->
  <div class="pages-title">
    <h2>Everything in one place</h2>
    <p>Four tools — one link to share with everyone.</p>
  </div>

  <div class="pages-grid">

    <a class="page-card" href="dashboard.html">
      <div class="page-card-top">
        <span class="page-card-icon">📊</span>
        <div class="page-card-title">Live Trading Dashboard</div>
        <div class="page-card-desc">Real wallet balance pulled from Solana mainnet. Every on-chain transaction with a Solscan link. SOL price from Binance. Auto-refreshes every 30 seconds.</div>
        <span class="page-card-tag tag-live">● Live Data</span>
      </div>
      <div class="page-card-bottom">
        <span class="page-card-link">Open dashboard →</span>
        <span class="page-card-arrow">↗</span>
      </div>
    </a>

    <a class="page-card" href="paper-dashboard.html">
      <div class="page-card-top">
        <span class="page-card-icon">🧪</span>
        <div class="page-card-title">Paper Trading Dashboard</div>
        <div class="page-card-desc">Real Jupiter quotes. Real spread calculations. Zero fake numbers. See exactly which pairs have arb opportunities right now — with full fee and slippage modeling.</div>
        <span class="page-card-tag tag-paper">⚠ Paper Trading</span>
      </div>
      <div class="page-card-bottom">
        <span class="page-card-link">View paper trader →</span>
        <span class="page-card-arrow">↗</span>
      </div>
    </a>

    <a class="page-card" href="investor-portal.html">
      <div class="page-card-top">
        <span class="page-card-icon">💎</span>
        <div class="page-card-title">Investor Portal</div>
        <div class="page-card-desc">Deposit SOL into the vault smart contract and earn a share of arbitrage profits. Fully on-chain, trustless, and transparent. Withdraw anytime after 7 days lockup.</div>
        <span class="page-card-tag tag-invest">◆ Earn Yield</span>
      </div>
      <div class="page-card-bottom">
        <span class="page-card-link">Start investing →</span>
        <span class="page-card-arrow">↗</span>
      </div>
    </a>

    <a class="page-card" href="sol-vault.zip">
      <div class="page-card-top">
        <span class="page-card-icon">📦</span>
        <div class="page-card-title">Smart Contract Source</div>
        <div class="page-card-desc">Download and audit the Solana vault smart contract. Written in Rust with Anchor framework. Verify exactly how deposits, profit sharing, and withdrawals work on-chain.</div>
        <span class="page-card-tag tag-code">↓ Open Source</span>
      </div>
      <div class="page-card-bottom">
        <span class="page-card-link">Download source →</span>
        <span class="page-card-arrow">↗</span>
      </div>
    </a>

  </div>

  <!-- FEATURES -->
  <div class="features">
    <div class="section-label">Why it works</div>
    <div class="section-h">Built for speed.<br>Designed for profit.</div>
    <div class="section-p">Every component optimized for low latency on Solana — the only chain fast enough for HFT arbitrage.</div>
    <div class="feat-grid">
      <div class="feat"><div class="feat-icon">⚡</div><div class="feat-title">500ms Scan Interval</div><div class="feat-desc">Scans all 12 token pairs every 500ms. Opportunities that last seconds get captured before anyone else sees them.</div></div>
      <div class="feat"><div class="feat-icon">🔀</div><div class="feat-title">Cross-DEX Routing</div><div class="feat-desc">Trades across Raydium, Orca, Jupiter, Meteora, and Phoenix simultaneously to find the best price spread.</div></div>
      <div class="feat"><div class="feat-icon">🛡️</div><div class="feat-title">Risk Management</div><div class="feat-desc">Daily loss limits, consecutive loss circuit breakers, slippage controls, and price impact filters protect your capital.</div></div>
      <div class="feat"><div class="feat-icon">🔗</div><div class="feat-title">Helius RPC</div><div class="feat-desc">Dedicated Helius node for lowest possible latency. Milliseconds matter — wired directly to the validators.</div></div>
      <div class="feat"><div class="feat-icon">📜</div><div class="feat-title">On-Chain Vault</div><div class="feat-desc">Funds held in a Solana smart contract PDA — not a centralized wallet. Withdrawals always available after lockup.</div></div>
      <div class="feat"><div class="feat-icon">👁️</div><div class="feat-title">Full Transparency</div><div class="feat-desc">Every trade on-chain. Every transaction visible on Solscan. Every profit verifiable by anyone, anytime.</div></div>
    </div>
  </div>

  <!-- STEPS -->
  <div class="steps">
    <div class="section-label">Process</div>
    <div class="section-h">How your SOL earns</div>
    <div class="steps-grid">
      <div class="step"><div class="step-num">01</div><div class="step-title">Deposit</div><div class="step-desc">Send min 0.5 SOL to the vault. You receive shares proportional to your deposit size.</div></div>
      <div class="step"><div class="step-num">02</div><div class="step-title">Bot Trades</div><div class="step-desc">The arb bot executes trades across Solana DEXes using your pooled capital.</div></div>
      <div class="step"><div class="step-num">03</div><div class="step-title">Profits Split</div><div class="step-desc">75% of all profits go to depositors. 25% is the manager performance fee. No fee on losses.</div></div>
      <div class="step"><div class="step-num">04</div><div class="step-title">Withdraw</div><div class="step-desc">After 7 days, withdraw your share plus profits instantly. No penalties, fully on-chain.</div></div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-banner">
    <h2>Ready to start earning?</h2>
    <p>Deposit SOL today and let the bot trade for you — fully automated, fully transparent.</p>
    <div class="cta-btns">
      <a class="btn btn-primary" href="investor-portal.html">◆ Open Investor Portal</a>
      <a class="btn btn-ghost" href="dashboard.html">View Live Dashboard</a>
      <a class="btn btn-ghost" href="paper-dashboard.html">View Paper Trader</a>
    </div>
  </div>

</div>

<footer>
  <div class="foot-inner">
    <span class="foot-text">SOL Arb Bot © 2025 — Trading involves risk. Past performance does not guarantee future results.</span>
    <div class="foot-links">
      <a href="dashboard.html">Dashboard</a>
      <a href="paper-dashboard.html">Paper Trader</a>
      <a href="investor-portal.html">Invest</a>
      <a href="https://solscan.io/account/DUyAnt9FVguy8sRQbRuNSW1tuToJfcqWq5sgwYRBtdF6" target="_blank">Solscan</a>
    </div>
  </div>
</footer>

<script>
(async()=>{
  try{
    const r = await fetch('https://api.binance.com/api/v3/ticker/price?symbol=SOLUSDT');
    const d = await r.json();
    document.getElementById('solPrice').textContent = '$'+parseFloat(d.price).toFixed(2);
  }catch(e){}
})();
</script>
</body>
</html>
